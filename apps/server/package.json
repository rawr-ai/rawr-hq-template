{
  "name": "@rawr/server",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@orpc/contract": "^1.13.5",
    "@orpc/openapi": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@rawr/core": "workspace:*",
    "@rawr/hq-app": "workspace:*",
    "@rawr/hq-ops": "workspace:*",
    "@rawr/runtime-context": "workspace:*",
    "elysia": "^1.3.12",
    "inngest": "3.51.0",
    "pino": "^10.3.1",
    "typebox": "^1.0.81"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "inngest-cli": "^1.16.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "dev:inngest": "env npm_config_ignore_scripts=false npm exec --yes --package=inngest-cli@latest -- inngest dev -u http://localhost:3000/api/inngest",
    "build": "bunx tsc -p tsconfig.json",
    "lint": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"**/*.{js,jsx,ts,tsx}\"",
    "sync": "bun run --cwd ../.. sync:check --project @rawr/server",
    "structural": "bun ../../scripts/phase-03/run-structural-suite.mjs --project @rawr/server",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project server",
    "orpc:openapi:write": "bun scripts/write-orpc-openapi.ts",
    "orpc:openapi:types": "bunx openapi-typescript ./openapi/orpc-openapi.json -o ./openapi/orpc-openapi.types.ts",
    "orpc:openapi:sdk": "bun run orpc:openapi:write && bun run orpc:openapi:types"
  },
  "nx": {
    "tags": [
      "type:app",
      "app:hq",
      "role:server",
      "migration-slice:structural-tranche"
    ]
  }
}
