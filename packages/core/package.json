{
  "name": "@rawr/core",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./orpc": {
      "types": "./src/orpc/index.ts",
      "default": "./src/orpc/index.ts"
    }
  },
  "dependencies": {
    "@oclif/core": "^4.2.10",
    "@orpc/contract": "^1.13.5",
    "@orpc/otel": "^1.13.6",
    "@orpc/server": "^1.13.5",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^2.6.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@rawr/coordination": "workspace:*",
    "@rawr/coordination-inngest": "workspace:*",
    "@rawr/coordination-observability": "workspace:*",
    "@rawr/state": "workspace:*",
    "inngest": "3.51.0"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
