{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "habitat",
  "root": "scripts/habitat",
  "sourceRoot": "scripts/habitat",
  "projectType": "application",
  "tags": ["type:tool", "role:architecture-policy"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx eslint scripts/habitat --ext .mjs"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test scripts/habitat/provision.test.mjs"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p scripts/habitat/tsconfig.json --noEmit"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "biome format --write ."
      }
    },
    "check:hygiene": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{workspaceRoot}/**/*"],
      "outputs": [],
      "options": {
        "command": "biome ci --diagnostic-level=error ."
      }
    },
    "lint:effect": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{workspaceRoot}/**/*.{js,jsx,ts,tsx,cjs,mjs,cts,mts}",
        "{workspaceRoot}/biome.json",
        "{workspaceRoot}/biome.effect.json",
        "{workspaceRoot}/package.json",
        "{workspaceRoot}/bun.lock",
        "{workspaceRoot}/patches/@catenarycloud%2Flinteffect@0.0.6.patch"
      ],
      "outputs": [],
      "options": {
        "command": "biome lint --config-path=biome.effect.json ."
      }
    },
    "check:policy": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{workspaceRoot}/**/AGENTS.md",
        "{workspaceRoot}/apps/**/*",
        "{workspaceRoot}/packages/**/*",
        "{workspaceRoot}/plugins/server/api/**/*",
        "{workspaceRoot}/plugins/async/**/*",
        "{workspaceRoot}/plugins/cli/**/*",
        "{workspaceRoot}/plugins/agents/**/*",
        "{workspaceRoot}/plugins/web/**/*",
        "{workspaceRoot}/resources/**/*",
        "{workspaceRoot}/services/**/*",
        "{workspaceRoot}/tools/**/*",
        "{workspaceRoot}/scripts/habitat/**/*",
        "{workspaceRoot}/scripts/nx/**/*",
        "{workspaceRoot}/.habitat/blueprints/**/*",
        "{workspaceRoot}/.habitat/rawr/agent-plugin-lifecycle/**/*",
        "{workspaceRoot}/.habitat/index.json",
        "{workspaceRoot}/scripts/habitat/provision.mjs",
        "{workspaceRoot}/scripts/habitat/release.json",
        "bunToolchain"
      ],
      "outputs": [],
      "options": {
        "command": "bun run habitat -- --rule require_blueprint_packet_topology --rule require_agent_router_placement --rule require_agent_router_shape --rule require_grit_helper_comments --rule require_api_server_plugin_boundary --rule require_agent_plugin_command_channel_topology --rule require_oclif_app_configuration --rule require_oclif_app_entrypoints --rule require_oclif_app_topology --rule require_oclif_command_plugin_configuration --rule require_oclif_command_plugin_topology --rule require_oclif_command_source_relationships"
      }
    },
    "check": {
      "executor": "nx:noop",
      "cache": false,
      "dependsOn": ["lint", "typecheck", "test", "check:hygiene", "check:policy"],
      "outputs": [],
      "options": {}
    }
  }
}
