{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "!{projectRoot}/dist/**", "!{projectRoot}/coverage/**"],
    "production": [
      "default",
      "!{projectRoot}/test/**",
      "!{projectRoot}/**/*.test.*",
      "!{projectRoot}/**/*.spec.*"
    ],
    "architectureGlobals": [
      "{workspaceRoot}/nx.json",
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/.habitat/**/*",
      "{workspaceRoot}/scripts/architecture/**/*.mjs",
      "{workspaceRoot}/scripts/habitat/**/*",
      "{workspaceRoot}/scripts/observability/**/*.mjs",
      "{workspaceRoot}/scripts/phase-a/**/*.mjs",
      "{workspaceRoot}/scripts/phase-2/**/*.mjs",
      "{workspaceRoot}/scripts/phase-03/**/*.mjs",
      "{workspaceRoot}/scripts/runtime/**/*.mjs",
      "{workspaceRoot}/tools/architecture-inventory/**/*.json"
    ],
    "typescriptRuntime": ["{workspaceRoot}/tsconfig.base.json", "{workspaceRoot}/bun.lock"],
    "bunToolchain": ["{workspaceRoot}/package.json", "{workspaceRoot}/bun.lock"]
  },
  "targetDefaults": {
    "check": {
      "cache": false,
      "dependsOn": ["lint", "typecheck", "verify", "check:policy", "^check"],
      "outputs": []
    },
    "build": {
      "cache": true,
      "inputs": ["production", "^production", "typescriptRuntime"],
      "outputs": ["{projectRoot}/dist"]
    },
    "manifest": {
      "cache": true,
      "dependsOn": ["build"],
      "inputs": [
        "production",
        "^production",
        "bunToolchain",
        "typescriptRuntime",
        "!{projectRoot}/oclif.manifest.json"
      ],
      "outputs": ["{projectRoot}/oclif.manifest.json"]
    },
    "typecheck": {
      "cache": true,
      "dependsOn": ["check:test", "check:tools"],
      "inputs": ["default", "^default", "typescriptRuntime"]
    },
    "check:test": {
      "cache": true,
      "inputs": ["default", "^default", "typescriptRuntime"],
      "outputs": []
    },
    "check:tools": {
      "cache": true,
      "inputs": ["default", "^default", "typescriptRuntime"],
      "outputs": []
    },
    "lint": {
      "cache": true,
      "inputs": ["default", "^default", "{workspaceRoot}/eslint.config.mjs"]
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^default", "typescriptRuntime", "{workspaceRoot}/vitest.config.ts"],
      "outputs": []
    },
    "sync": {
      "cache": false,
      "inputs": ["default", "^default", "architectureGlobals"]
    },
    "structural": {
      "cache": false,
      "dependsOn": ["sync"],
      "inputs": ["default", "^default", "architectureGlobals"]
    }
  },
  "sync": {
    "globalGenerators": ["./tools/nx/generators.json:sync-slice-0-inventory"]
  }
}
