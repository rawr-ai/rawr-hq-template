{
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "name": "plugin-async-workflow-foundry-proof",
  "root": "plugins/async/workflows/foundry-proof",
  "sourceRoot": "plugins/async/workflows/foundry-proof/src",
  "tags": [
    "type:plugin",
    "migration-slice:runtime-production",
    "role:async",
    "surface:workflow",
    "capability:foundry-proof"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p plugins/async/workflows/foundry-proof/tsconfig.json"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p plugins/async/workflows/foundry-proof/tsconfig.json --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"plugins/async/workflows/foundry-proof/**/*.{js,jsx,ts,tsx}\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test plugins/async/workflows/foundry-proof/test"
      }
    },
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run sync:check --project plugin-async-workflow-foundry-proof"
      }
    },
    "structural": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun scripts/runtime-prod/verify-capability-foundry-slice.mjs --name foundry-proof"
      }
    }
  }
}
