{
  "name": "@rawr/agent-config-sync",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "imports": {
    "#repositories/*": {
      "types": "./src/service/common/repositories/*.ts",
      "default": "./src/service/common/repositories/*.ts"
    },
    "#common/*": {
      "types": "./src/service/common/*.ts",
      "default": "./src/service/common/*.ts"
    },
    "#source-content/*": {
      "types": "./src/service/common/source-content/*.ts",
      "default": "./src/service/common/source-content/*.ts"
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./service/contract": {
      "types": "./src/service/contract.ts",
      "default": "./src/service/contract.ts"
    },
    "./resources": {
      "types": "./src/service/common/resources.ts",
      "default": "./src/service/common/resources.ts"
    },
    "./undo": {
      "types": "./src/undo.ts",
      "default": "./src/undo.ts"
    },
    "./entities": {
      "types": "./src/service/common/entities.ts",
      "default": "./src/service/common/entities.ts"
    },
    "./router": {
      "types": "./src/router.ts",
      "default": "./src/router.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "sync": "bun run --cwd ../.. sync:check --project @rawr/agent-config-sync",
    "structural": "bun ../../scripts/phase-03/run-structural-suite.mjs --project @rawr/agent-config-sync",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project agent-config-sync"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@orpc/contract": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@rawr/hq-sdk": "workspace:*",
    "smol-toml": "^1.6.1",
    "typebox": "^1.0.81",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "typescript": "^5.9.3"
  },
  "nx": {
    "tags": [
      "type:service",
      "role:servicepackage",
      "migration-slice:structural-tranche"
    ]
  }
}
