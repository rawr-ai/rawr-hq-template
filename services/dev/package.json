{
  "name": "@rawr/dev",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./service/contract": {
      "types": "./src/service/contract.ts",
      "default": "./src/service/contract.ts"
    },
    "./resources": {
      "types": "./src/service/common/resources.ts",
      "default": "./src/service/common/resources.ts"
    },
    "./router": {
      "types": "./src/router.ts",
      "default": "./src/router.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "sync": "bun run --cwd ../.. sync:check --project @rawr/dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project dev"
  },
  "dependencies": {
    "@rawr/hq-sdk": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@orpc/contract": "1.14.8",
    "@orpc/server": "1.14.8",
    "typebox": "1.3.6"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@types/node": "^22.14.0",
    "typescript": "^5.9.3"
  },
  "nx": {
    "tags": [
      "type:service",
      "role:servicepackage",
      "migration-slice:workstream-b-devops"
    ]
  }
}
