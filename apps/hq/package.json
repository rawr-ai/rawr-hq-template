{
  "name": "@rawr/hq-app",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./manifest": {
      "types": "./rawr.hq.ts",
      "default": "./rawr.hq.ts"
    },
    "./legacy-cutover": {
      "types": "./legacy-cutover.ts",
      "default": "./legacy-cutover.ts"
    }
  },
  "dependencies": {
    "@orpc/contract": "1.14.8",
    "@orpc/server": "1.14.8",
    "@rawr/example-todo": "workspace:*",
    "@rawr/hq-sdk": "workspace:*",
    "@rawr/runtime-context": "workspace:*",
    "inngest": "3.51.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.10",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"**/*.{js,jsx,ts,tsx}\"",
    "sync": "bun run --cwd ../.. sync:check --project @rawr/hq-app",
    "structural": "bun ../../scripts/phase-03/run-structural-suite.mjs --project @rawr/hq-app",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bunx vitest run --project hq-app"
  },
  "nx": {
    "implicitDependencies": [
      "plugin-server-api-example-todo"
    ],
    "tags": [
      "type:app",
      "app:hq",
      "migration-slice:structural-tranche"
    ]
  }
}
