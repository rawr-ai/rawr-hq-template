{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "repository",
  "root": "scripts/nx",
  "sourceRoot": "scripts/nx",
  "projectType": "application",
  "tags": ["type:tool", "role:repository-check"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/scripts/nx/tsconfig.json",
        "{workspaceRoot}/scripts/architecture/verify-repository-separation.mjs",
        "typescriptRuntime"
      ],
      "options": {
        "command": "tsc -p scripts/nx/tsconfig.json --noEmit"
      }
    },
    "check:boundaries": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [],
      "options": {
        "command": "bun scripts/architecture/verify-repository-separation.mjs"
      }
    },
    "verify": {
      "executor": "nx:noop",
      "dependsOn": ["check:boundaries"]
    },
    "check": {
      "executor": "nx:noop"
    }
  }
}
