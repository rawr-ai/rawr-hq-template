{
  "name": "@rawr/hq-sdk",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./boundary": {
      "types": "./src/boundary.ts",
      "default": "./src/boundary.ts"
    },
    "./host-adapters/analytics/embedded-placeholder": {
      "types": "./src/host-adapters/analytics/embedded-placeholder.ts",
      "default": "./src/host-adapters/analytics/embedded-placeholder.ts"
    },
    "./host-adapters/feedback/embedded-placeholder": {
      "types": "./src/host-adapters/feedback/embedded-placeholder.ts",
      "default": "./src/host-adapters/feedback/embedded-placeholder.ts"
    },
    "./host-adapters/logger/embedded-placeholder": {
      "types": "./src/host-adapters/logger/embedded-placeholder.ts",
      "default": "./src/host-adapters/logger/embedded-placeholder.ts"
    },
    "./host-adapters/sql/embedded-in-memory": {
      "types": "./src/host-adapters/sql/embedded-in-memory.ts",
      "default": "./src/host-adapters/sql/embedded-in-memory.ts"
    },
    "./workflows": {
      "types": "./src/workflows.ts",
      "default": "./src/workflows.ts"
    }
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@orpc/contract": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "inngest": "3.51.0",
    "typebox": "^1.0.81"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "nx": {
    "tags": [
      "type:package"
    ]
  }
}
