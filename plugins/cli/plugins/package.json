{
  "name": "@rawr/plugin-plugins",
  "version": "0.1.0",
  "private": true,
  "description": "Unified plugins command surface for sync, runtime web plugins, and plugin scaffolding",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.7",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oclif/core": "^4.8.0",
    "@rawr/agent-config-sync": "workspace:*",
    "@rawr/core": "workspace:*",
    "@rawr/hq-ops": "workspace:*",
    "yaml": "^2.8.1",
    "yazl": "^3.3.1"
  },
  "oclif": {
    "commands": "./src/commands",
    "topicSeparator": " ",
    "typescript": {
      "commands": "./src/commands"
    }
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "^5.9.3",
    "@types/yazl": "^3.2.6"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "sync": "bun run --cwd ../../.. sync:check --project @rawr/plugin-plugins",
    "structural": "bun ../../../scripts/phase-03/run-structural-suite.mjs --project @rawr/plugin-plugins",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project plugin-plugins",
    "lint": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"**/*.{js,jsx,ts,tsx}\""
  },
  "rawr": {
    "kind": "toolkit",
    "capability": "plugins"
  },
  "nx": {
    "tags": [
      "type:plugin",
      "migration-slice:structural-tranche"
    ]
  }
}
