{
  "name": "@rawr/agent-plugin-build",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"**/*.{js,jsx,ts,tsx}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun --bun ../../node_modules/.bin/vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@rawr/agent-plugin-release": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "nx": {
    "tags": [
      "type:service",
      "role:agent-plugin-build"
    ]
  }
}
