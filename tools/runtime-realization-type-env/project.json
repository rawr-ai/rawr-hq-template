{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "runtime-realization-type-env",
  "root": "tools/runtime-realization-type-env",
  "sourceRoot": "tools/runtime-realization-type-env/src",
  "tags": ["type:tool", "migration-slice:runtime-realization", "spec-conformance"],
  "targets": {
    "check": {
      "executor": "nx:noop"
    },
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run sync:check --project runtime-realization-type-env"
      }
    },
    "structural": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun tools/runtime-realization-type-env/scripts/verify-structure.ts"
      }
    },
    "report": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun tools/runtime-realization-type-env/scripts/report-results.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tools/runtime-realization-type-env/tsconfig.json --noEmit"
      }
    },
    "negative": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun tools/runtime-realization-type-env/scripts/assert-negative-types.ts"
      }
    },
    "vendor-effect": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test tools/runtime-realization-type-env/test/vendor/effect-runtime.test.ts"
      }
    },
    "vendor-boundaries": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test tools/runtime-realization-type-env/test/vendor"
      }
    },
    "oracle": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test tools/runtime-realization-type-env/test/oracle"
      }
    },
    "middle-spine": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test tools/runtime-realization-type-env/test/conformance/middle-spine-derivation.test.ts"
      }
    },
    "simulate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun test tools/runtime-realization-type-env/test/conformance/spine-simulation.test.ts"
      }
    },
    "gate": {
      "executor": "nx:noop",
      "dependsOn": [
        "sync",
        "structural",
        "report",
        {
          "projects": ["habitat"],
          "target": "lint"
        },
        "typecheck",
        "negative",
        "vendor-effect",
        "vendor-boundaries",
        "oracle",
        "middle-spine",
        "simulate"
      ]
    }
  }
}
