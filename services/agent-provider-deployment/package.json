{
  "name": "@rawr/agent-provider-deployment",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./adapters/codex": {
      "types": "./src/adapters/codex.ts",
      "default": "./src/adapters/codex.ts"
    },
    "./adapters/claude": {
      "types": "./src/adapters/claude.ts",
      "default": "./src/adapters/claude.ts"
    },
    "./adapters/node-codex": {
      "types": "./src/adapters/node-codex.ts",
      "default": "./src/adapters/node-codex.ts"
    },
    "./adapters/node-claude": {
      "types": "./src/adapters/node-claude.ts",
      "default": "./src/adapters/node-claude.ts"
    },
    "./node-state": {
      "types": "./src/node-state/index.ts",
      "default": "./src/node-state/index.ts"
    },
    "./owner-protocol": {
      "types": "./src/owner-protocol/index.ts",
      "default": "./src/owner-protocol/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"**/*.{js,jsx,ts,tsx}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun --bun ../../node_modules/.bin/vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@rawr/agent-plugin-release": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "nx": {
    "tags": [
      "type:service",
      "role:agent-provider-deployment"
    ]
  }
}
