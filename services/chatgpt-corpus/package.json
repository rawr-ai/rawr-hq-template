{
  "name": "@rawr/chatgpt-corpus",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./orpc/ports/workspace-store": {
      "types": "./src/orpc/ports/workspace-store.ts",
      "default": "./src/orpc/ports/workspace-store.ts"
    },
    "./service/contract": {
      "types": "./src/service/contract.ts",
      "default": "./src/service/contract.ts"
    },
    "./router": {
      "types": "./src/router.ts",
      "default": "./src/router.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "structural": "bun ../../scripts/phase-03/run-structural-suite.mjs --project @rawr/chatgpt-corpus",
    "test": "vitest run --project chatgpt-corpus"
  },
  "dependencies": {
    "@rawr/hq-sdk": "workspace:*",
    "@orpc/contract": "1.14.8",
    "@orpc/server": "1.14.8",
    "typebox": "1.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.2.10",
    "@types/node": "^22.14.0",
    "typescript": "^5.9.3"
  },
  "nx": {
    "tags": [
      "type:service",
      "role:servicepackage"
    ]
  }
}
