{
  "name": "@rawr/hq-app",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./manifest": {
      "types": "./rawr.hq.ts",
      "default": "./rawr.hq.ts"
    }
  },
  "dependencies": {
    "@orpc/contract": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@rawr/example-todo": "workspace:*",
    "@rawr/hq-sdk": "workspace:*",
    "@rawr/plugin-server-api-example-todo": "workspace:*",
    "@rawr/plugin-server-api-state": "workspace:*",
    "@rawr/sdk": "workspace:*",
    "inngest": "3.51.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.10",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"**/*.{js,jsx,ts,tsx}\"",
    "sync": "bun run --cwd ../.. sync:check --project @rawr/hq-app",
    "structural": "bun ../../scripts/phase-03/run-structural-suite.mjs --project @rawr/hq-app",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bunx vitest run --project hq-app"
  },
  "nx": {
    "tags": [
      "type:app",
      "app:hq",
      "migration-slice:structural-tranche"
    ],
    "targets": {
      "build": {
        "cache": true,
        "inputs": [
          "production",
          "^production",
          "!{projectRoot}/test/**",
          "!{projectRoot}/**/*.test.ts",
          "!{projectRoot}/**/*.test.tsx",
          "!{projectRoot}/**/*.spec.ts",
          "!{projectRoot}/**/*.spec.tsx"
        ],
        "outputs": [
          "{projectRoot}/dist"
        ]
      }
    }
  }
}
