{
  "name": "@rawr/support-example",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "main": "./src/router.ts",
  "types": "./src/router.ts",
  "exports": {
    "./router": {
      "types": "./src/router.ts",
      "default": "./src/router.ts"
