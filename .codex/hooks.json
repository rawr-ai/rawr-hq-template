{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/workstream_startup.py\"",
            "timeout": 5,
            "statusMessage": "Loading workstream startup checklist"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/workstream_report_health.py\"",
            "timeout": 8,
            "statusMessage": "Checking workstream artifact health"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/workstream_closure_guard.py\"",
            "timeout": 10,
            "statusMessage": "Checking workstream closure readiness"
          }
        ]
      }
    ]
  }
}
