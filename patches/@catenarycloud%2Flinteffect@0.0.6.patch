--- a/rules/no-effect-succeed-variable.grit
+++ b/rules/no-effect-succeed-variable.grit
@@ -12,7 +12,7 @@ file($body) where {
         register_diagnostic(
             span = $lift,
             message = "Rule: avoid Effect.succeed(variable) as a branch placeholder. Why: it hides a decision and turns data into pseudo-control flow. Fix: select a plain value (Option/Match) and then run one Effect pipeline after the decision; if you already read the state, return it as a value. Avoid Option.toArray/forEach hacks that just re-encode the branch.",
