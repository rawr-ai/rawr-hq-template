{
  "name": "@rawr/state",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./orpc": {
      "types": "./src/orpc/index.ts",
      "default": "./src/orpc/index.ts"
    }
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "sync": "bun run --cwd ../.. sync:check --project @rawr/state",
    "structural": "bun ../../scripts/phase-03/run-structural-suite.mjs --project @rawr/state",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project state"
  },
  "dependencies": {
    "@orpc/contract": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "typebox": "^1.0.81"
  },
  "nx": {
    "tags": [
      "type:package",
      "migration-slice:structural-tranche"
    ]
  }
}
