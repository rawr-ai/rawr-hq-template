{
  "name": "@rawr/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14",
    "node": "^20.17.0 || >=22.9.0"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.100",
    "@oclif/core": "^4.11.4",
    "@oclif/plugin-help": "^6.2.27",
    "@oclif/plugin-plugins": "^5.4.36",
    "@orpc/client": "1.14.8",
    "@rawr/agent-plugin-lifecycle": "workspace:*",
    "@rawr/core": "workspace:*",
    "@rawr/hq-ops": "workspace:*",
    "@rawr/plugin-chatgpt-corpus": "workspace:*",
    "@rawr/plugin-devops": "workspace:*",
    "@rawr/plugin-hyperresearch": "workspace:*",
    "@rawr/plugin-session-tools": "workspace:*",
    "@rawr/resource-agent-plugin-package-output": "workspace:*",
    "@rawr/resource-content-workspace": "workspace:*",
    "@rawr/resource-native-agent-provider": "workspace:*",
    "effect": "4.0.0-beta.100",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bun": "^1.2.10",
    "@types/node": "^22.14.0",
    "typescript": "^5.9.3"
  },
  "oclif": {
    "bin": "rawr",
    "dirname": "rawr",
    "commands": "./dist/commands",
    "topicSeparator": " ",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins",
      "@rawr/plugin-chatgpt-corpus",
      "@rawr/plugin-devops",
      "@rawr/plugin-hyperresearch",
      "@rawr/plugin-session-tools"
    ],
    "typescript": {
      "commands": "./src/commands"
    }
  },
  "scripts": {
    "rawr": "bun src/index.ts",
    "dev:cli": "bun src/index.ts",
    "check": "bun run lint && bun run typecheck",
    "build": "tsc -p tsconfig.build.json",
    "sync": "bun run --cwd ../.. sync:check --project @rawr/cli",
    "structural": "bun ../../scripts/phase-03/run-structural-suite.mjs --project @rawr/cli",
    "structure-oclif": "bun run --cwd ../.. habitat -- --rule require_oclif_app_configuration --rule require_oclif_app_topology",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "TMPDIR=/tmp bun --bun ../../node_modules/.bin/vitest run --project cli",
    "test-oclif-boundary": "TMPDIR=/tmp bun --bun ../../node_modules/.bin/vitest run --project cli test/bin-run.test.ts --testNamePattern='discovers the same commands from source and compiled output'",
    "acceptance-oclif-plugins": "TMPDIR=/tmp bun --bun ../../node_modules/.bin/vitest run --project cli-native-acceptance",
    "lint": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"**/*.{js,jsx,ts,tsx}\""
  },
  "bin": {
    "rawr": "./bin/run.js"
  },
  "nx": {
    "tags": [
      "type:app",
      "app:hq",
      "role:cli",
      "migration-slice:structural-tranche"
    ],
    "targets": {
      "test": {
        "dependsOn": [
          "build",
          {
            "projects": [
              "@rawr/plugin-chatgpt-corpus",
              "@rawr/plugin-devops",
              "@rawr/plugin-hello",
              "@rawr/plugin-hyperresearch",
              "@rawr/plugin-session-tools"
            ],
            "target": "build"
          }
        ]
      },
      "structure-oclif": {
        "cache": true,
        "inputs": [
          "default",
          "{workspaceRoot}/.habitat/blueprints/oclif-app/**/*",
          "{workspaceRoot}/scripts/habitat/**/*",
          "bunToolchain"
        ],
        "outputs": []
      },
      "test-oclif-boundary": {
        "cache": true,
        "dependsOn": [
          "build",
          {
            "projects": [
              "@rawr/plugin-chatgpt-corpus",
              "@rawr/plugin-devops",
              "@rawr/plugin-hyperresearch",
              "@rawr/plugin-session-tools"
            ],
            "target": "build"
          }
        ],
        "inputs": [
          "default",
          "^default",
          "typescriptRuntime",
          "{workspaceRoot}/vitest.config.ts"
        ],
        "outputs": []
      },
      "acceptance-oclif-plugins": {
        "cache": false,
        "dependsOn": [
          "test-oclif-boundary",
          {
            "projects": [
              "@rawr/plugin-hello"
            ],
            "target": "manifest"
          }
        ],
        "inputs": [
          "default",
          "^default",
          "typescriptRuntime",
          "{workspaceRoot}/vitest.config.ts"
        ],
        "outputs": []
      }
    }
  }
}
