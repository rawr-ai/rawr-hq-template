{
  "name": "@rawr/agent-plugin-lifecycle",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./release": {
      "types": "./src/service/shared/release/index.ts",
      "default": "./src/service/shared/release/index.ts"
    },
    "./service/contract": {
      "types": "./src/service/contract.ts",
      "default": "./src/service/contract.ts"
    },
    "./router": {
      "types": "./src/router.ts",
      "default": "./src/router.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"**/*.{js,jsx,ts,tsx}\"",
    "sync": "bun run --cwd ../.. sync:check --project @rawr/agent-plugin-lifecycle",
    "structural": "bun ../../scripts/phase-03/run-structural-suite.mjs --project @rawr/agent-plugin-lifecycle",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun --bun ../../node_modules/.bin/vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@rawr/hq-sdk": "workspace:*",
    "@rawr/resource-agent-plugin-artifact-repository": "workspace:*",
    "@rawr/resource-agent-plugin-package-output": "workspace:*",
    "@rawr/resource-agent-provider-records": "workspace:*",
    "@rawr/resource-content-workspace": "workspace:*",
    "@rawr/resource-native-agent-provider": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@orpc/contract": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "typebox": "1.3.6"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@types/bun": "^1.2.10",
    "@types/node": "^22.14.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "nx": {
    "tags": [
      "type:service",
      "role:servicepackage",
      "migration-slice:structural-tranche"
    ]
  }
}
