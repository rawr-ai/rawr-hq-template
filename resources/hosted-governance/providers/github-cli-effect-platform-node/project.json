{
  "name": "provider-hosted-governance-github-cli-effect-platform-node",
  "projectType": "library",
  "sourceRoot": "resources/hosted-governance/providers/github-cli-effect-platform-node",
  "tags": [
    "type:provider",
    "layer:resource-provider",
    "resource:hosted-governance",
    "provider:github-cli-effect-platform-node"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/resources/hosted-governance/dist"],
      "options": {
        "command": "tsc -p resources/hosted-governance/tsconfig.build.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"{projectRoot}/**/*.ts\""
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p {projectRoot}/tsconfig.json --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx vitest run --config {projectRoot}/vitest.config.ts"
      }
    }
  }
}
