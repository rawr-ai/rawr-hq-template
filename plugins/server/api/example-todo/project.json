{
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "name": "plugin-server-api-example-todo",
  "root": "plugins/server/api/example-todo",
  "sourceRoot": "plugins/server/api/example-todo/src",
  "implicitDependencies": ["@rawr/example-todo", "@rawr/hq-sdk", "@rawr/runtime-context"],
  "tags": [
    "type:plugin",
    "migration-slice:structural-tranche",
    "role:server",
    "surface:api",
    "capability:example-todo"
  ],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/tsconfig.json",
        "typescriptRuntime",
        "^production"
      ],
      "outputs": [],
      "options": {
        "command": "tsc -p plugins/server/api/example-todo/tsconfig.json --noEmit"
      }
    },
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run sync:check --project plugin-server-api-example-todo"
      }
    },
    "structural": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/**/*",
        "{workspaceRoot}/.habitat/blueprints/plugin-server-api/require_api_server_plugin_boundary/**/*",
        "{workspaceRoot}/scripts/habitat/provision.mjs",
        "{workspaceRoot}/scripts/habitat/release.json",
        "bunToolchain"
      ],
      "outputs": [],
      "options": {
        "command": "bun run habitat -- --rule require_api_server_plugin_boundary"
      }
    },
    "check": {
      "executor": "nx:noop"
    }
  }
}
