{
  "name": "@rawr/plugin-hello",
  "version": "0.1.0",
  "private": true,
  "description": "RAWR HQ-Template sample oclif plugin",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "oclif.manifest.json",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oclif/core": "^4.2.10"
  },
  "oclif": {
    "commands": "./dist/commands",
    "topicSeparator": " ",
    "typescript": {
      "commands": "./src/commands"
    }
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "oclif": "4.23.27",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "manifest": "bun --bun oclif manifest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck-tests": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --project plugin-hello",
    "lint": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"**/*.{js,jsx,ts,tsx}\""
  },
  "nx": {
    "tags": [
      "type:plugin"
    ],
    "targets": {
      "typecheck": {
        "dependsOn": [
          "typecheck-tests"
        ],
        "inputs": [
          "production",
          "^production",
          "typescriptRuntime"
        ]
      }
    }
  }
}
