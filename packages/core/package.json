{
  "name": "@rawr/core",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./telemetry": {
      "types": "./src/telemetry.ts",
      "default": "./src/telemetry.ts"
    }
  },
  "dependencies": {
    "@oclif/core": "^4.2.10",
    "@orpc/otel": "^1.13.6",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^2.6.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"**/*.{js,jsx,ts,tsx}\"",
    "sync": "bun run --cwd ../.. sync:check --project @rawr/core",
    "structural": "bun ../../scripts/phase-03/run-structural-suite.mjs --project @rawr/core",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project core"
  },
  "nx": {
    "tags": [
      "type:package",
      "migration-slice:structural-tranche"
    ],
    "targets": {
      "build": {
        "cache": true,
        "inputs": [
          "production",
          "^production",
          "!{projectRoot}/test/**",
          "!{projectRoot}/**/*.test.ts",
          "!{projectRoot}/**/*.test.tsx",
          "!{projectRoot}/**/*.spec.ts",
          "!{projectRoot}/**/*.spec.tsx"
        ],
        "outputs": [
          "{projectRoot}/dist"
        ]
      }
    }
  }
}
