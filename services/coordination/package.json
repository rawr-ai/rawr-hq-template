{
  "name": "@rawr/coordination",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./events": {
      "types": "./src/domain/events.ts",
      "default": "./src/domain/events.ts"
    },
    "./domain/schemas": {
      "types": "./src/domain/schemas.ts",
      "default": "./src/domain/schemas.ts"
    },
    "./service/contract": {
      "types": "./src/service/contract.ts",
      "default": "./src/service/contract.ts"
    },
    "./service/modules/runs/schemas": {
      "types": "./src/service/modules/runs/schemas.ts",
      "default": "./src/service/modules/runs/schemas.ts"
    },
    "./service/modules/workflows/schemas": {
      "types": "./src/service/modules/workflows/schemas.ts",
      "default": "./src/service/modules/workflows/schemas.ts"
    },
    "./router": {
      "types": "./src/router.ts",
      "default": "./src/router.ts"
    },
    "./compat/http": {
      "types": "./src/compat/http.ts",
      "default": "./src/compat/http.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "default": "./src/node.ts"
    }
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "lint": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"**/*.{js,jsx,ts,tsx}\"",
    "sync": "bun run --cwd ../.. sync:check --project @rawr/coordination",
    "structural": "bun ../../scripts/phase-03/run-structural-suite.mjs --project @rawr/coordination",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project coordination"
  },
  "dependencies": {
    "@rawr/hq-sdk": "workspace:*",
    "typebox": "^1.0.81"
  },
  "nx": {
    "tags": [
      "type:service",
      "role:servicepackage",
      "migration-slice:structural-tranche"
    ]
  }
}
