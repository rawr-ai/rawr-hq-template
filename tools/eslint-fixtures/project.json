{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "eslint-fixtures",
  "root": "tools/eslint-fixtures",
  "sourceRoot": "tools/eslint-fixtures",
  "tags": [
    "type:package",
    "migration-slice:structural-tranche"
  ],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint --max-warnings 0 --no-error-on-unmatched-pattern \"tools/eslint-fixtures/**/*.{js,jsx,ts,tsx}\""
      }
    },
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run sync:check --project eslint-fixtures"
      }
    },
    "structural": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun scripts/phase-03/verify-eslint-fixtures-structural.mjs"
      }
    }
  }
}
