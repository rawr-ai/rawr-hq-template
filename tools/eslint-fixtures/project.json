{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "eslint-fixtures",
  "root": "tools/eslint-fixtures",
  "sourceRoot": "tools/eslint-fixtures",
  "tags": [
    "type:package",
    "migration-slice:structural-tranche"
  ],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun scripts/phase-03/verify-eslint-fixtures-lint.mjs"
      },
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/eslint.config.mjs",
        "{workspaceRoot}/scripts/phase-03/verify-eslint-fixtures-lint.mjs"
      ]
    },
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run sync:check --project eslint-fixtures"
      }
    },
    "structural": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun scripts/phase-03/verify-eslint-fixtures-structural.mjs"
      }
    }
  }
}
